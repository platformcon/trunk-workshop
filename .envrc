# direnv config: use Trunk-managed hermetic tools for this repo.
#
# After `direnv allow`, `node`/`npm`/`npx` resolve to the Trunk-pinned versions
# (see .trunk/trunk.yaml) instead of whatever is installed globally — so every
# contributor and CI run uses the same toolchain.
#
# Requirements (one-time, see README):
#   - the Trunk CLI:  https://docs.trunk.io/cli
#   - direnv, hooked into your shell:  https://direnv.net/docs/hook.html
if ! has trunk; then
  log_error "Trunk CLI not found. Install it: curl https://get.trunk.io -fsSL | bash"
else
  # The shims live in .trunk/tools (gitignored), so a fresh clone has to
  # generate them once. Cheap to re-check; only installs when missing.
  if [ ! -x .trunk/tools/npm ]; then
    log_status "Generating Trunk tool shims (node, npm, npx)…"
    trunk install >/dev/null
  fi
  PATH_add .trunk/tools
fi
